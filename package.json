{
  "name": "jalenclaw",
  "version": "0.1.0",
  "description": "Multi-channel AI assistant platform",
  "type": "module",
  "bin": {
    "jalenclaw": "dist/index.js"
  },
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/ tests/",
    "lint:fix": "eslint src/ tests/ --fix",
    "prepare": "simple-git-hooks"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20.11.0",
    "@types/ws": "^8.18.1",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^9.1.0",
    "simple-git-hooks": "^2.11.0",
    "typescript": "^5.5.0",
    "typescript-eslint": "^8.0.0",
    "vitest": "^2.0.0"
  },
  "dependencies": {
    "@whiskeysockets/baileys": "7.0.0-rc.9",
    "better-sqlite3": "^12.8.0",
    "commander": "^14.0.3",
    "grammy": "^1.41.1",
    "pino": "^10.3.1",
    "ws": "^8.19.0",
    "yaml": "^2.8.2",
    "zod": "^3.23.0"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm run typecheck && pnpm run lint"
  }
}
